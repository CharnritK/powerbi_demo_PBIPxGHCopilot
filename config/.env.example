# Compatibility copy of the canonical root .env.example.
# Prefer the repo-root .env for day-to-day work.
# Use config/.env only when you intentionally want the loader fallback path.
APP_ENV=dev
TENANT_ID=your-tenant-id-guid
CLIENT_ID=your-client-id-guid
CLIENT_SECRET=
WORKSPACE_ID=
DATASET_ID=
DAX_QUERY=EVALUATE ROW("Demo", 1)
IMPERSONATED_USER_NAME=
AUTH_MODE=delegated
REDIRECT_URI=http://localhost
USE_DEVICE_CODE=true
LOG_LEVEL=INFO
TOKEN_CACHE_PATH=.local/msal_token_cache.bin
REQUEST_TIMEOUT_SECONDS=60

# Legacy aliases remain available for older workshop flows.
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=
PBI_REDIRECT_URI=
PBI_AUTH_MODE=
PBI_WORKSPACE_ID=
PBI_DATASET_ID=
PBI_TIMEOUT_SECONDS=
PBI_LOG_LEVEL=
